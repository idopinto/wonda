# Environment variables for wonda
# Copy this file to .env and fill in your values

# =============================================================================
# API Keys (optional - only needed for specific model backends)
# =============================================================================

# OpenAI API key (for GPT models via OpenAI API)
# OPENAI_API_KEY=sk-...

# Together AI API key (for Together AI inference)
# TOGETHER_API_KEY=...

# OpenRouter API key (for OpenRouter inference)
# OPENROUTER_API_KEY=...

# =============================================================================
# HuggingFace (optional - only needed for private models/datasets)
# =============================================================================

# HuggingFace token (for private models or pushing to Hub)
# HF_TOKEN=hf_...

# =============================================================================
# Experiment Tracking (optional)
# =============================================================================

# Weights & Biases API key (for experiment tracking)
# WANDB_API_KEY=...

# =============================================================================
# Runtime Configuration (optional)
# =============================================================================

# Weave parallelism (default: 1)
# Controls concurrent model inference calls
# WEAVE_PARALLELISM=1

# Maximum concurrent verifier processes (default: 1)
# VERIFIER_MAX_CONCURRENT=1
